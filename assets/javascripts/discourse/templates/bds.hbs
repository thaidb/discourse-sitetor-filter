{{#if this.siteSettings.sitetor_bds_enabled}}
  <div class="sitetor-bds">
    <h1>{{i18n "sitetor_bds.title"}}</h1>

    <div class="bds-filters">
      <div class="bds-filter-group">
        <label>{{i18n "sitetor_bds.gia"}} ({{i18n "sitetor_bds.trieu"}})</label>
        <Input @value={{this.fGiaMin}} placeholder="min" type="number" />
        <span>–</span>
        <Input @value={{this.fGiaMax}} placeholder="max" type="number" />
      </div>

      <div class="bds-filter-group">
        <label>{{i18n "sitetor_bds.mat_tien"}} (m)</label>
        <Input @value={{this.fMtMin}} placeholder="min" type="number" />
        <span>–</span>
        <Input @value={{this.fMtMax}} placeholder="max" type="number" />
      </div>

      <div class="bds-filter-group">
        <label>{{i18n "sitetor_bds.dien_tich"}} (m²)</label>
        <Input @value={{this.fDtMin}} placeholder="min" type="number" />
        <span>–</span>
        <Input @value={{this.fDtMax}} placeholder="max" type="number" />
      </div>

      <DButton
        @action={{this.applyFilter}}
        @icon="magnifying-glass"
        @label="sitetor_bds.loc"
        class="btn-primary"
      />
      <DButton @action={{this.resetFilter}} @label="sitetor_bds.xoa_loc" />
    </div>

    <p class="bds-total">{{i18n "sitetor_bds.tong" count=this.total}}</p>

    <div class="bds-table-wrap">
      <table class="bds-table">
        <thead>
          <tr>
            <th>{{i18n "sitetor_bds.tin"}}</th>
            <th>{{i18n "sitetor_bds.gia"}}</th>
            <th>{{i18n "sitetor_bds.mat_tien"}}</th>
            <th>{{i18n "sitetor_bds.dien_tich"}}</th>
            <th>{{i18n "sitetor_bds.tags"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.topics as |t|}}
            <tr>
              <td class="bds-title">
                <a href="/t/{{t.slug}}/{{t.id}}">{{t.title}}</a>
              </td>
              <td class="bds-num">{{format-bds-gia t.gia}}</td>
              <td class="bds-num">{{if t.mat_tien t.mat_tien "—"}}</td>
              <td class="bds-num">{{if t.dien_tich t.dien_tich "—"}}</td>
              <td class="bds-tags">
                {{#each t.tags as |tag|}}<span class="bds-tag">{{tag}}</span>{{/each}}
              </td>
            </tr>
          {{else}}
            <tr><td colspan="5">{{i18n "sitetor_bds.khong_co"}}</td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="bds-paging">
      <DButton @action={{this.prevPage}} @disabled={{unless this.hasPrev true}} @label="sitetor_bds.truoc" />
      <span>{{i18n "sitetor_bds.trang" page=this.page}}</span>
      <DButton @action={{this.nextPage}} @disabled={{unless this.hasNext true}} @label="sitetor_bds.sau" />
    </div>
  </div>
{{/if}}
